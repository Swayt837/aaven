# ---- BioBoost — variables d'environnement ----
# Copie ce fichier en .env et remplis les valeurs.
# L'app FONCTIONNE sans rien remplir (mode démo) :
#  - sans Google : un "dev login" crée un compte de démo
#  - sans Stripe : les tips simulent un paiement réussi

# Port du serveur API
PORT=3001

# Environnement : "production" active le cookie sécurisé (HTTPS), désactive le dev-login
# et exige un vrai SESSION_SECRET. Laisse vide en local.
NODE_ENV=

# Secret de session (signe le cookie). Mets une longue chaîne aléatoire.
# Génère-en une : node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
SESSION_SECRET=change-moi-en-prod

# URL publique du site (pour les redirections OAuth/Stripe et le QR code)
# En dev, le client Vite tourne sur 5180 (voir vite.config.js).
APP_URL=http://localhost:5180

# ---- Base de données ----
# VIDE en local → SQLite (server/bioboost.db). DÉFINI → PostgreSQL (Supabase).
# Supabase : Project Settings → Database → Connection string → onglet "Session pooler"
# (compatible serveur Node persistant + IPv4). Remplace [YOUR-PASSWORD]. Exemple :
#   postgresql://postgres.xxxx:MOTDEPASSE@aws-0-eu-west-3.pooler.supabase.com:5432/postgres
DATABASE_URL=
# PGSSL=disable uniquement pour un Postgres local sans TLS (Supabase = laisser vide).
PGSSL=

# ---- Stockage des fichiers ----
# Priorité : Cloudflare R2 (si R2_* définis) → Supabase Storage → disque local (dev).
#
# Cloudflare R2 (RECOMMANDÉ en prod — egress GRATUIT) :
#   Cloudflare → R2 → crée 2 buckets : "aaven-public" (accès public + domaine cdn.aaven.fr) et "aaven-private".
#   Crée un token API R2 (Account ID + Access Key + Secret).
#   R2_PUBLIC_BASE_URL = l'URL publique du bucket public (domaine perso, ex. https://cdn.aaven.fr).
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_PUBLIC_BUCKET=aaven-public
R2_PRIVATE_BUCKET=aaven-private
R2_PUBLIC_BASE_URL=

# ---- Cache CDN Cloudflare (optionnel) ----
# Les pages publiques sont mises en cache à l'edge (s-maxage 300s). Si tu fournis un token,
# le cache d'une page est purgé automatiquement dès qu'elle est modifiée (sinon : visible au bout du TTL).
# CF_API_TOKEN : Cloudflare → My Profile → API Tokens → token avec permission « Zone → Cache Purge ».
# CF_ZONE_ID   : Cloudflare → ton domaine → Overview (colonne droite) → Zone ID.
CF_API_TOKEN=
CF_ZONE_ID=

# Supabase Storage (fallback) — utilisé seulement si R2_* sont vides.
# DÉFINI → Supabase Storage. Crée 2 buckets : "uploads" (public) et "product-files" (privé).
# SUPABASE_URL : Project Settings → API → Project URL (https://xxxx.supabase.co)
# SUPABASE_SERVICE_KEY : Project Settings → API → service_role key (SECRET, serveur uniquement)
SUPABASE_URL=
SUPABASE_SERVICE_KEY=
# Noms de buckets (optionnel, défauts ci-dessous)
SUPABASE_BUCKET=uploads
SUPABASE_PRIVATE_BUCKET=product-files

# ---- Google OAuth (optionnel) ----
# https://console.cloud.google.com/apis/credentials
# Redirect URI à configurer : {APP_URL}/api/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ---- Stripe (optionnel) ----
# Paiements (tips + produits) + Connect Express (versement aux créateurs) + Billing (abonnements).
# Active Stripe Connect (Express) dans ton dashboard Stripe. Webhook → {APP_URL}/api/stripe/webhook
# (events: checkout.session.completed, account.updated, customer.subscription.updated|deleted)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# Price IDs des abonnements (Stripe Billing) — Creator 7€/mois, Pro 15€/mois
STRIPE_PRICE_CREATOR=
STRIPE_PRICE_PRO=

# ---- E-mail / SMTP (optionnel) ----
# Active la notif e-mail à l'owner quand un visiteur envoie un message via le formulaire.
# Sans ces variables : les messages sont seulement stockés (consultables dans Stats).
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=Aaven <no-reply@aaven.fr>

# ---- Wallet (optionnel) — bouton "Ajouter à Apple/Google Wallet" sur la page publique ----
# Tant que ces variables sont vides, les boutons Wallet sont masqués.
# Apple Wallet : compte Apple Developer. Exporte tes certificats en PEM puis encode-les en base64 :
#   base64 -w0 signerCert.pem  /  signerKey.pem  /  wwdr.pem
APPLE_PASS_TYPE_ID=
APPLE_TEAM_ID=
APPLE_ORG_NAME=Aaven
APPLE_CERT_SIGNER_B64=
APPLE_CERT_KEY_B64=
APPLE_CERT_WWDR_B64=
APPLE_CERT_KEY_PASSWORD=
# Google Wallet : Google Pay & Wallet Console (gratuit). Issuer ID + compte de service (JSON).
# GOOGLE_WALLET_SA_KEY_B64 = la "private_key" du JSON, encodée en base64.
GOOGLE_WALLET_ISSUER_ID=
GOOGLE_WALLET_SA_EMAIL=
GOOGLE_WALLET_SA_KEY_B64=

# ---- Analytics produit PostHog (optionnel, côté client) ----
# Variables VITE_ = injectées dans le build front (clé projet = publique, c'est normal).
# Sans VITE_POSTHOG_KEY : pas d'analytics ni de bandeau de consentement.
# Choisis l'EU Cloud pour le RGPD. PostHog ne démarre qu'après consentement (opt-in).
VITE_POSTHOG_KEY=
VITE_POSTHOG_HOST=https://eu.i.posthog.com
